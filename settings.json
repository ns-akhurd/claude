{
  "awsAuthRefresh": "aws sso login --profile NSBedrockViewer-242201274356",
  "env": {
    "AWS_PROFILE": "NSBedrockViewer-242201274356",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_REGION": "us-east-1",
    "ENABLE_LSP_TOOL": "1",
    "PATH": "/root/go/bin:/usr/local/bin:/usr/bin:/bin:/usr/local/go/bin"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "Task",
      "mcp__plugin_slack_slack__*",
      "mcp__plugin_context-mode_context-mode__*",
      "Skill",
      "Agent",
      "AskUserQuestion",
      "LSP",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskOutput",
      "TaskStop",
      "EnterPlanMode",
      "ExitPlanMode",
      "CronCreate",
      "CronList",
      "CronDelete",
      "Edit(/root/.claude/*)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(rmdir *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(shutdown*)",
      "Bash(reboot*)",
      "Bash(halt*)",
      "Bash(chmod 777 *)",
      "Bash(> /etc/*)"
    ],
    "defaultMode": "dontAsk"
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|WebFetch|Read|Grep|Agent|Task|mcp__plugin_context-mode_context-mode__ctx_execute|mcp__plugin_context-mode_context-mode__ctx_execute_file|mcp__plugin_context-mode_context-mode__ctx_batch_execute",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/plugins/cache/context-mode/context-mode/1.0.20/hooks/pretooluse.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/plugins/cache/context-mode/context-mode/1.0.20/hooks/posttooluse.mjs"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json,os,subprocess; d=json.loads(os.environ.get('CLAUDE_TOOL_INPUT','{}')); f=d.get('file_path',''); f and any(f.endswith(e) for e in ('.cpp','.hpp','.h','.c')) and subprocess.run(['/opt/llvm-21/bin/clang-format','-i',f])\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/root/.claude/plugins/cache/context-mode/context-mode/1.0.20/hooks/sessionstart.mjs\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/plugins/cache/context-mode/context-mode/1.0.20/hooks/precompact.mjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/plugins/cache/context-mode/context-mode/1.0.20/hooks/userpromptsubmit.mjs"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh 'Claude needs your permission!'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh 'Claude finished!'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/bin/bash /root/.claude/statusline-robbyrussell.sh"
  },
  "enabledPlugins": {
    "voicemode@voicemode": false,
    "eng-skills@netskope": true,
    "clangd-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "context-mode@context-mode": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    }
  },
  "effortLevel": "high"
}
