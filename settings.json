{
  "cleanupPeriodDays": 90,
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "PATH": "/root/go/bin:/usr/local/bin:/usr/bin:/bin:/usr/local/go/bin:/mnt/c/Windows/System32:/mnt/c/Windows/System32/WindowsPowerShell/v1.0",
    "ENABLE_TOOL_SEARCH": "true",
    "ENABLE_PROMPT_CACHING_1H_BEDROCK": "1",
    "BASH_MAX_OUTPUT_LENGTH": "100000",
    "CLAUDE_CODE_ENABLE_TASKS": "1",
    "CLAUDE_CODE_ENABLE_AUTO_MODE": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "high",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "100000",
    "COLORTERM": "truecolor"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "Task",
      "mcp__plugin_slack_slack__*",
      "mcp__slack__*",
      "mcp__plugin_jira__*",
      "mcp__plugin_confluence__*",
      "mcp__plugin_context-mode_context-mode__*",
      "mcp__plugin_context7_context7__*",
      "Skill",
      "Agent",
      "AskUserQuestion",
      "LSP",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskOutput",
      "TaskStop",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "ExitWorktree",
      "ListMcpResourcesTool",
      "ReadMcpResourceTool",
      "CronCreate",
      "CronList",
      "CronDelete"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rmdir *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(shutdown*)",
      "Bash(reboot*)",
      "Bash(halt*)",
      "Bash(chmod 777 *)",
      "Bash(> /etc/*)"
    ],
    "defaultMode": "dontAsk",
    "additionalDirectories": [
      "/root/.claude"
    ]
  },
  "model": "sonnet",
  "skillOverrides": {
    "init-agent-os": "off"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/post-clang-format.sh"
          },
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/strip-crlf.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/sounds.sh notify",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh 'Claude needs your permission!'"
          },
          {
            "type": "command",
            "command": "~/.claude/sounds.sh alert",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/rule-11-4-trigger.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /root/.claude/hooks/terse-mode.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh 'Claude finished!'"
          },
          {
            "type": "command",
            "command": "~/.claude/sounds.sh done",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-robbyrussell.sh",
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "eng-skills@netskope": true,
    "clangd-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": false,
    "slack@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "netskope": {
      "source": {
        "source": "github",
        "repo": "netSkope/claude-skills"
      }
    }
  },
  "alwaysThinkingEnabled": false,
  "effortLevel": "high",
  "autoDreamEnabled": true,
  "showThinkingSummaries": true,
  "skipWorkflowUsageWarning": true,
  "autoCompactEnabled": true,
  "autoScrollEnabled": false,
  "fileCheckpointingEnabled": true,
  "showTurnDuration": true,
  "showMessageTimestamps": true,
  "todoFeatureEnabled": true
}
